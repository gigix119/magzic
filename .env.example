# Copy this file to .env and fill in the real values.
# NEVER commit your .env file to the repository — keep secrets local or in your hosting dashboard.

# Supabase (Settings → API in Supabase Dashboard)
# VITE_SUPABASE_URL is the Project URL (e.g. https://<ref>.supabase.co)
# VITE_SUPABASE_ANON_KEY is the anon public key — safe to expose in the frontend if RLS is enabled
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: server-side AI endpoint URL for invoice parsing (no API key exposed to frontend)
# Points to a Cloudflare Worker or Supabase Edge Function that holds the actual AI key server-side.
# Leave empty to use the local text-based parser only.
VITE_INVOICE_AI_ENDPOINT=
