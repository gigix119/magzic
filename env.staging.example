# ============================================================
# Magzic – Staging environment variables
# Copy this file to .env.staging (covered by .env.* gitignore rule — never committed) and fill in values.
# This template file (env.staging.example) has no secrets and IS safe to commit.
# ============================================================

# Supabase staging project (Settings → API in the staging project dashboard)
VITE_SUPABASE_URL=https://<staging-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<staging-anon-key>

# Optional: staging AI endpoint (can leave empty to use local parser only)
VITE_INVOICE_AI_ENDPOINT=
